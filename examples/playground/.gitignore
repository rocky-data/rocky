# Rocky runtime artifacts
.rocky-state.redb
*.duckdb
*.duckdb.wal
*.duckdb.tmp/

# Captured POC outputs (regenerated by run.sh)
pocs/**/expected/*.json
pocs/**/expected/*.dot
pocs/**/expected/*.txt
!pocs/**/expected/.gitkeep

# Python (benchmarks, dbt-migration POC)
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
.python-version

# Rust (in case anyone scratches a Rust file here)
target/

# Editor / OS / agents
.DS_Store
.idea/
.vscode/
.claude/
*.swp

# Secrets — never commit
.env
.env.*
!.env.example

# Scratch space
scratch/
tmp/
