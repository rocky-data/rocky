{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "definitions": {
    "ModelEstimate": {
      "description": "Cost estimate for a single model.",
      "properties": {
        "estimated_bytes_scanned": {
          "description": "Estimated bytes that would be scanned (if available).",
          "format": "uint64",
          "minimum": 0.0,
          "type": [
            "integer",
            "null"
          ]
        },
        "estimated_rows": {
          "description": "Estimated number of rows (if available).",
          "format": "uint64",
          "minimum": 0.0,
          "type": [
            "integer",
            "null"
          ]
        },
        "model_name": {
          "type": "string"
        },
        "raw_explain": {
          "description": "Raw EXPLAIN output from the warehouse.",
          "type": "string"
        }
      },
      "required": [
        "model_name",
        "raw_explain"
      ],
      "type": "object"
    }
  },
  "description": "JSON output for `rocky estimate`.",
  "properties": {
    "command": {
      "type": "string"
    },
    "estimates": {
      "items": {
        "$ref": "#/definitions/ModelEstimate"
      },
      "type": "array"
    },
    "total_models": {
      "format": "uint",
      "minimum": 0.0,
      "type": "integer"
    },
    "version": {
      "type": "string"
    }
  },
  "required": [
    "command",
    "estimates",
    "total_models",
    "version"
  ],
  "title": "EstimateOutput",
  "type": "object"
}
