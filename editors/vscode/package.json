{
  "name": "rocky",
  "displayName": "Rocky",
  "description": "Language support for Rocky SQL transformation engine",
  "version": "1.0.0",
  "publisher": "rocky-data",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/rocky-data/rocky",
    "directory": "editors/vscode"
  },
  "engines": {
    "vscode": "^1.110.0"
  },
  "icon": "icons/rocky-icon-128.png",
  "galleryBanner": {
    "color": "#1e1e1e",
    "theme": "dark"
  },
  "categories": [
    "Programming Languages",
    "Linters",
    "Snippets"
  ],
  "activationEvents": [
    "onLanguage:rocky",
    "workspaceContains:**/*.rocky",
    "workspaceContains:rocky.toml"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "rocky",
        "aliases": [
          "Rocky",
          "rocky"
        ],
        "extensions": [
          ".rocky"
        ],
        "icon": {
          "light": "./icons/rocky-icon.svg",
          "dark": "./icons/rocky-icon.svg"
        },
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "rocky",
        "scopeName": "source.rocky",
        "path": "./syntaxes/rocky.tmLanguage.json"
      }
    ],
    "snippets": [
      {
        "language": "rocky",
        "path": "./snippets/rocky.json"
      }
    ],
    "configuration": {
      "title": "Rocky",
      "properties": {
        "rocky.server.path": {
          "type": "string",
          "default": "rocky",
          "description": "Path to the Rocky binary"
        },
        "rocky.server.extraArgs": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "Extra arguments to pass to rocky lsp"
        },
        "rocky.inlayHints.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Show inferred types inline"
        }
      }
    },
    "commands": [
      {
        "command": "rocky.codeLens.runModel",
        "title": "Run Model (Terminal)",
        "category": "Rocky"
      },
      {
        "command": "rocky.codeLens.compileModel",
        "title": "Compile Model (Terminal)",
        "category": "Rocky"
      },
      {
        "command": "rocky.restartServer",
        "title": "Restart Language Server",
        "category": "Rocky"
      },
      {
        "command": "rocky.showLineage",
        "title": "Show Model Lineage",
        "category": "Rocky"
      },
      {
        "command": "rocky.compile",
        "title": "Compile Models",
        "category": "Rocky"
      },
      {
        "command": "rocky.validate",
        "title": "Validate Configuration",
        "category": "Rocky"
      },
      {
        "command": "rocky.ci",
        "title": "Run CI (Compile + Test)",
        "category": "Rocky"
      },
      {
        "command": "rocky.test",
        "title": "Run Tests",
        "category": "Rocky"
      },
      {
        "command": "rocky.run",
        "title": "Run Pipeline",
        "category": "Rocky"
      },
      {
        "command": "rocky.plan",
        "title": "Plan Pipeline (Dry Run)",
        "category": "Rocky"
      },
      {
        "command": "rocky.discover",
        "title": "Discover Sources",
        "category": "Rocky"
      },
      {
        "command": "rocky.compare",
        "title": "Compare Shadow vs Production",
        "category": "Rocky"
      },
      {
        "command": "rocky.history",
        "title": "Show Run History",
        "category": "Rocky"
      },
      {
        "command": "rocky.metrics",
        "title": "Show Model Metrics",
        "category": "Rocky"
      },
      {
        "command": "rocky.compact",
        "title": "Compact Table",
        "category": "Rocky"
      },
      {
        "command": "rocky.archive",
        "title": "Archive Old Partitions",
        "category": "Rocky"
      },
      {
        "command": "rocky.profileStorage",
        "title": "Profile Table Storage",
        "category": "Rocky"
      },
      {
        "command": "rocky.aiGenerate",
        "title": "Generate Model from Intent",
        "category": "Rocky"
      },
      {
        "command": "rocky.aiSync",
        "title": "Sync Models (AI Schema Change Detection)",
        "category": "Rocky"
      },
      {
        "command": "rocky.aiExplain",
        "title": "Explain Model (Generate Intent)",
        "category": "Rocky"
      },
      {
        "command": "rocky.aiTest",
        "title": "Generate Tests from Intent",
        "category": "Rocky"
      },
      {
        "command": "rocky.importDbt",
        "title": "Import dbt Project",
        "category": "Rocky"
      },
      {
        "command": "rocky.validateMigration",
        "title": "Validate dbt Migration",
        "category": "Rocky"
      },
      {
        "command": "rocky.hooksList",
        "title": "List Configured Hooks",
        "category": "Rocky"
      },
      {
        "command": "rocky.hooksTest",
        "title": "Test Hook Event",
        "category": "Rocky"
      },
      {
        "command": "rocky.doctor",
        "title": "Run Health Check",
        "category": "Rocky"
      },
      {
        "command": "rocky.optimize",
        "title": "Analyze Cost & Optimization",
        "category": "Rocky"
      },
      {
        "command": "rocky.refreshModels",
        "title": "Refresh Models",
        "category": "Rocky",
        "icon": "$(refresh)"
      },
      {
        "command": "rocky.refreshRuns",
        "title": "Refresh Runs",
        "category": "Rocky",
        "icon": "$(refresh)"
      },
      {
        "command": "rocky.refreshSources",
        "title": "Refresh Sources",
        "category": "Rocky",
        "icon": "$(refresh)"
      }
    ],
    "semanticTokenScopes": [
      {
        "language": "rocky",
        "scopes": {
          "namespace": [
            "entity.name.type.model.rocky"
          ],
          "variable": [
            "variable.other.column.rocky"
          ],
          "function": [
            "entity.name.function.sql.rocky"
          ],
          "keyword": [
            "keyword.control.rocky"
          ],
          "macro": [
            "entity.name.function.macro.rocky"
          ]
        }
      }
    ],
    "jsonValidation": [
      {
        "fileMatch": "rocky.toml",
        "url": "./schemas/rocky-project.schema.json"
      },
      {
        "fileMatch": "*.rocky.toml",
        "url": "./schemas/rocky-config.schema.json"
      }
    ],
    "taskDefinitions": [
      {
        "type": "rocky",
        "required": [
          "command"
        ],
        "properties": {
          "command": {
            "type": "string",
            "description": "Rocky subcommand to run (e.g. compile, test, ci, validate, run)"
          },
          "args": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Extra arguments appended to the rocky subcommand"
          }
        }
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "rocky",
          "title": "Rocky",
          "icon": "icons/rocky-icon.svg"
        }
      ]
    },
    "views": {
      "rocky": [
        {
          "id": "rocky.models",
          "name": "Models",
          "icon": "icons/rocky-icon.svg",
          "contextualTitle": "Rocky Models"
        },
        {
          "id": "rocky.runs",
          "name": "Runs",
          "icon": "icons/rocky-icon.svg",
          "contextualTitle": "Rocky Run History"
        },
        {
          "id": "rocky.sources",
          "name": "Sources",
          "icon": "icons/rocky-icon.svg",
          "contextualTitle": "Rocky Sources"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "rocky.refreshModels",
          "when": "view == rocky.models",
          "group": "navigation"
        },
        {
          "command": "rocky.refreshRuns",
          "when": "view == rocky.runs",
          "group": "navigation"
        },
        {
          "command": "rocky.refreshSources",
          "when": "view == rocky.sources",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "rocky.compile",
          "when": "view == rocky.models && viewItem == rockyModel",
          "group": "1_run@1"
        },
        {
          "command": "rocky.test",
          "when": "view == rocky.models && viewItem == rockyModel",
          "group": "1_run@2"
        },
        {
          "command": "rocky.showLineage",
          "when": "view == rocky.models && viewItem == rockyModel",
          "group": "2_inspect@1"
        },
        {
          "command": "rocky.history",
          "when": "view == rocky.models && viewItem == rockyModel",
          "group": "2_inspect@2"
        },
        {
          "command": "rocky.metrics",
          "when": "view == rocky.models && viewItem == rockyModel",
          "group": "2_inspect@3"
        },
        {
          "command": "rocky.optimize",
          "when": "view == rocky.models && viewItem == rockyModel",
          "group": "2_inspect@4"
        }
      ]
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src/",
    "bundle:webview": "node scripts/bundle-webview.mjs",
    "pretest": "npm run compile",
    "test": "node ./out/test/runTest.js",
    "test:unit": "vitest run",
    "test:all": "npm run test:unit && npm test",
    "package": "vsce package",
    "package:local": "vsce package -o rocky.vsix",
    "install:local": "npm run package:local && code --install-extension rocky.vsix --force",
    "uninstall:local": "code --uninstall-extension rocky-data.rocky",
    "vscode:prepublish": "npm run bundle:webview && npm run compile"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^25.5.2",
    "@types/vscode": "^1.110.0",
    "@viz-js/viz": "^3.25.0",
    "@vscode/test-electron": "^2.5.2",
    "@vscode/vsce": "^3.7.1",
    "eslint": "^10.2.0",
    "glob": "^13.0.6",
    "json-schema-to-typescript": "^15.0.4",
    "mocha": "^11.7.5",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.0",
    "vitest": "^4.1.3"
  },
  "overrides_comment": "Force-patch transitive deps that mocha 11.x hasn't bumped yet — fixes Dependabot alerts #17 (jsdiff DoS), #18 (serialize-javascript RCE), #19 (serialize-javascript CPU exhaustion). Drop these once mocha upstreams the bumps.",
  "overrides": {
    "serialize-javascript": "^7.0.5",
    "diff": "^8.0.3"
  }
}
