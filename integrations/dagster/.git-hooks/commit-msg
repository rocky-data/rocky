#!/bin/sh
# .git-hooks/commit-msg
# Validates commit messages follow conventional commits format

# Enable strict mode
set -euo pipefail

# Get the commit message file path
COMMIT_MSG_FILE="$1"

# Read the commit message (strip comments)
COMMIT_MSG=$(grep -v '^#' "$COMMIT_MSG_FILE" | head -n1)

# Skip validation for empty messages (git will handle this)
if [ -z "$COMMIT_MSG" ]; then
    exit 0
fi

# Skip validation for merge commits
if echo "$COMMIT_MSG" | grep -qE '^Merge '; then
    exit 0
fi

# Skip validation for revert commits (auto-generated by git)
if echo "$COMMIT_MSG" | grep -qE '^Revert "'; then
    exit 0
fi

# Skip validation for fixup/squash commits (used in interactive rebase)
if echo "$COMMIT_MSG" | grep -qE '^(fixup|squash)! '; then
    exit 0
fi

# Define valid commit types
TYPES="feat|fix|docs|style|refactor|perf|test|build|ci|chore|revert"

# Conventional commit pattern:
# <type>(<scope>)?!?: <description>
# Examples:
#   feat: add new feature
#   fix(auth): resolve login bug
#   feat(api)!: breaking change
PATTERN="^($TYPES)(\([a-zA-Z0-9_-]+\))?!?: .+$"

if ! echo "$COMMIT_MSG" | grep -qE "$PATTERN"; then
    echo ""
    echo "Invalid commit message format"
    echo ""
    echo "Your message:"
    echo "  $COMMIT_MSG"
    echo ""
    echo "Expected format:"
    echo "  <type>(<scope>): <description>"
    echo ""
    echo "Valid types: feat, fix, docs, style, refactor, perf, test, build, ci, chore, revert"
    echo ""
    echo "Examples:"
    echo "  feat: add user authentication"
    echo "  fix(rocky): resolve sync timing issue"
    echo "  docs: update API documentation"
    echo ""
    exit 1
fi

exit 0
