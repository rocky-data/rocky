{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "definitions": {
    "ModelExecutionRecord": {
      "description": "One model execution from the state store, mirroring `rocky_core::state::ModelExecution`.",
      "properties": {
        "duration_ms": {
          "format": "uint64",
          "minimum": 0.0,
          "type": "integer"
        },
        "rows_affected": {
          "format": "uint64",
          "minimum": 0.0,
          "type": [
            "integer",
            "null"
          ]
        },
        "sql_hash": {
          "type": "string"
        },
        "started_at": {
          "format": "date-time",
          "type": "string"
        },
        "status": {
          "type": "string"
        }
      },
      "required": [
        "duration_ms",
        "sql_hash",
        "started_at",
        "status"
      ],
      "type": "object"
    }
  },
  "description": "JSON output for `rocky history --model <name>`.",
  "properties": {
    "command": {
      "type": "string"
    },
    "count": {
      "format": "uint",
      "minimum": 0.0,
      "type": "integer"
    },
    "executions": {
      "items": {
        "$ref": "#/definitions/ModelExecutionRecord"
      },
      "type": "array"
    },
    "model": {
      "type": "string"
    },
    "version": {
      "type": "string"
    }
  },
  "required": [
    "command",
    "count",
    "executions",
    "model",
    "version"
  ],
  "title": "ModelHistoryOutput",
  "type": "object"
}
