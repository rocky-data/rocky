{
  "name": "rocky",
  "displayName": "Rocky",
  "description": "Language support for Rocky SQL transformation engine",
  "version": "1.15.1",
  "publisher": "rocky-data",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/rocky-data/rocky",
    "directory": "editors/vscode"
  },
  "engines": {
    "vscode": "^1.116.0"
  },
  "icon": "icons/rocky-icon-128.png",
  "galleryBanner": {
    "color": "#0F1518",
    "theme": "dark"
  },
  "categories": [
    "Programming Languages",
    "Linters",
    "Snippets"
  ],
  "activationEvents": [
    "onLanguage:rocky",
    "workspaceContains:**/*.rocky",
    "workspaceContains:rocky.toml",
    "onView:rocky.getStarted",
    "onView:rocky.info",
    "onView:rocky.help"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "rocky",
        "aliases": [
          "Rocky",
          "rocky"
        ],
        "extensions": [
          ".rocky"
        ],
        "icon": {
          "light": "./icons/rocky-icon.svg",
          "dark": "./icons/rocky-icon.svg"
        },
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "rocky",
        "scopeName": "source.rocky",
        "path": "./syntaxes/rocky.tmLanguage.json"
      }
    ],
    "snippets": [
      {
        "language": "rocky",
        "path": "./snippets/rocky.json"
      }
    ],
    "configuration": {
      "title": "Rocky",
      "properties": {
        "rocky.server.path": {
          "type": "string",
          "default": "rocky",
          "description": "Path to the Rocky binary"
        },
        "rocky.server.extraArgs": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "Extra arguments to pass to rocky lsp"
        },
        "rocky.inlayHints.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Show inferred types inline"
        }
      }
    },
    "commands": [
      {
        "command": "rocky.commandPalette",
        "title": "Rocky Command Palette",
        "category": "Rocky"
      },
      {
        "command": "rocky.codeLens.runModel",
        "title": "Run Model (Terminal)",
        "category": "Rocky"
      },
      {
        "command": "rocky.codeLens.compileModel",
        "title": "Compile Model (Terminal)",
        "category": "Rocky"
      },
      {
        "command": "rocky.restartServer",
        "title": "Restart Language Server",
        "category": "Rocky"
      },
      {
        "command": "rocky.showLineage",
        "title": "Show Model Lineage",
        "category": "Rocky"
      },
      {
        "command": "rocky.compile",
        "title": "Compile Models",
        "category": "Rocky"
      },
      {
        "command": "rocky.validate",
        "title": "Validate Configuration",
        "category": "Rocky"
      },
      {
        "command": "rocky.ci",
        "title": "Run CI (Compile + Test)",
        "category": "Rocky"
      },
      {
        "command": "rocky.test",
        "title": "Run Tests",
        "category": "Rocky"
      },
      {
        "command": "rocky.run",
        "title": "Run Pipeline",
        "category": "Rocky"
      },
      {
        "command": "rocky.plan",
        "title": "Plan Pipeline (Dry Run)",
        "category": "Rocky"
      },
      {
        "command": "rocky.discover",
        "title": "Discover Sources",
        "category": "Rocky"
      },
      {
        "command": "rocky.compare",
        "title": "Compare Shadow vs Production",
        "category": "Rocky"
      },
      {
        "command": "rocky.history",
        "title": "Show Run History",
        "category": "Rocky"
      },
      {
        "command": "rocky.metrics",
        "title": "Show Model Metrics",
        "category": "Rocky"
      },
      {
        "command": "rocky.catalog",
        "title": "Build Project Catalog (Column Lineage Snapshot)",
        "category": "Rocky"
      },
      {
        "command": "rocky.compact",
        "title": "Compact Table",
        "category": "Rocky"
      },
      {
        "command": "rocky.archive",
        "title": "Archive Old Partitions",
        "category": "Rocky"
      },
      {
        "command": "rocky.profileStorage",
        "title": "Profile Table Storage",
        "category": "Rocky"
      },
      {
        "command": "rocky.aiGenerate",
        "title": "Generate Model from Intent",
        "category": "Rocky"
      },
      {
        "command": "rocky.aiSync",
        "title": "Sync Models (AI Schema Change Detection)",
        "category": "Rocky"
      },
      {
        "command": "rocky.aiExplain",
        "title": "Explain Model (Generate Intent)",
        "category": "Rocky"
      },
      {
        "command": "rocky.aiTest",
        "title": "Generate Tests from Intent",
        "category": "Rocky"
      },
      {
        "command": "rocky.importDbt",
        "title": "Import dbt Project",
        "category": "Rocky"
      },
      {
        "command": "rocky.validateMigration",
        "title": "Validate dbt Migration",
        "category": "Rocky"
      },
      {
        "command": "rocky.hooksList",
        "title": "List Configured Hooks",
        "category": "Rocky"
      },
      {
        "command": "rocky.hooksTest",
        "title": "Test Hook Event",
        "category": "Rocky"
      },
      {
        "command": "rocky.doctor",
        "title": "Run Health Check",
        "category": "Rocky"
      },
      {
        "command": "rocky.optimize",
        "title": "Analyze Cost & Optimization",
        "category": "Rocky"
      },
      {
        "command": "rocky.previewCreate",
        "title": "Rocky: Preview Create (PR diff)",
        "category": "Rocky"
      },
      {
        "command": "rocky.previewDiff",
        "title": "Rocky: Preview Diff",
        "category": "Rocky"
      },
      {
        "command": "rocky.previewCost",
        "title": "Rocky: Preview Cost",
        "category": "Rocky"
      },
      {
        "command": "rocky.branchApprove",
        "title": "Rocky: Branch Approve",
        "category": "Rocky"
      },
      {
        "command": "rocky.branchPromote",
        "title": "Rocky: Branch Promote",
        "category": "Rocky"
      },
      {
        "command": "rocky.refreshModels",
        "title": "Refresh Models",
        "category": "Rocky",
        "icon": "$(refresh)"
      },
      {
        "command": "rocky.refreshRuns",
        "title": "Refresh Runs",
        "category": "Rocky",
        "icon": "$(refresh)"
      },
      {
        "command": "rocky.refreshSources",
        "title": "Refresh Sources",
        "category": "Rocky",
        "icon": "$(refresh)"
      },
      {
        "command": "rocky.refreshInfo",
        "title": "Refresh Extension Info",
        "category": "Rocky",
        "icon": "$(refresh)"
      },
      {
        "command": "rocky.openOutputChannel",
        "title": "Show Output Channel",
        "category": "Rocky"
      },
      {
        "command": "rocky.openDocumentation",
        "title": "Open Documentation",
        "category": "Rocky"
      },
      {
        "command": "rocky.reportBug",
        "title": "Report a Bug",
        "category": "Rocky"
      },
      {
        "command": "rocky.viewMarketplace",
        "title": "View on Marketplace",
        "category": "Rocky"
      },
      {
        "command": "rocky.init",
        "title": "Initialize Project",
        "category": "Rocky"
      },
      {
        "command": "rocky.playground",
        "title": "Open Playground",
        "category": "Rocky"
      }
    ],
    "semanticTokenScopes": [
      {
        "language": "rocky",
        "scopes": {
          "namespace": [
            "entity.name.type.model.rocky"
          ],
          "variable": [
            "variable.other.column.rocky"
          ],
          "function": [
            "entity.name.function.sql.rocky"
          ],
          "keyword": [
            "keyword.control.rocky"
          ],
          "macro": [
            "entity.name.function.macro.rocky"
          ]
        }
      }
    ],
    "jsonValidation": [
      {
        "fileMatch": "rocky.toml",
        "url": "./schemas/rocky-project.schema.json"
      },
      {
        "fileMatch": "*.rocky.toml",
        "url": "./schemas/rocky-config.schema.json"
      }
    ],
    "taskDefinitions": [
      {
        "type": "rocky",
        "required": [
          "command"
        ],
        "properties": {
          "command": {
            "type": "string",
            "description": "Rocky subcommand to run (e.g. compile, test, ci, validate, run)"
          },
          "args": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Extra arguments appended to the rocky subcommand"
          }
        }
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "rocky",
          "title": "Rocky",
          "icon": "icons/rocky-activity-bar.svg"
        }
      ]
    },
    "views": {
      "rocky": [
        {
          "id": "rocky.getStarted",
          "name": "Get Started",
          "type": "tree",
          "icon": "icons/rocky-icon.svg",
          "contextualTitle": "Get Started with Rocky",
          "visibility": "visible"
        },
        {
          "id": "rocky.info",
          "name": "Extension Info",
          "type": "tree",
          "icon": "icons/rocky-icon.svg",
          "contextualTitle": "Rocky Extension Info",
          "visibility": "collapsed"
        },
        {
          "id": "rocky.models",
          "name": "Models",
          "icon": "icons/rocky-icon.svg",
          "contextualTitle": "Rocky Models"
        },
        {
          "id": "rocky.runs",
          "name": "Runs",
          "icon": "icons/rocky-icon.svg",
          "contextualTitle": "Rocky Run History",
          "visibility": "collapsed"
        },
        {
          "id": "rocky.sources",
          "name": "Sources",
          "icon": "icons/rocky-icon.svg",
          "contextualTitle": "Rocky Sources",
          "visibility": "collapsed"
        },
        {
          "id": "rocky.help",
          "name": "Help",
          "type": "tree",
          "icon": "icons/rocky-icon.svg",
          "contextualTitle": "Rocky Help",
          "visibility": "collapsed"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "rocky.getStarted",
        "contents": "Open a folder containing a Rocky project to get started.\n\n[Open Folder](command:vscode.openFolder)\n\nLearn more about Rocky in the [documentation](https://github.com/rocky-data/rocky#readme).",
        "when": "workbenchState == empty"
      },
      {
        "view": "rocky.getStarted",
        "contents": "No Rocky project detected in this workspace.\n\n[Initialize Rocky Project](command:rocky.init)\n[Try the Playground](command:rocky.playground)\n[Open Documentation](command:rocky.openDocumentation)",
        "when": "workbenchState != empty && !rocky.hasProject"
      },
      {
        "view": "rocky.getStarted",
        "contents": "Quick actions for your Rocky project.\n\n[Compile Models](command:rocky.compile)\n[Plan Pipeline (Dry Run)](command:rocky.plan)\n[Run Pipeline](command:rocky.run)\n[Discover Sources](command:rocky.discover)\n[Run Health Check](command:rocky.doctor)",
        "when": "rocky.hasProject"
      },
      {
        "view": "rocky.models",
        "contents": "Open a Rocky project to see your models.\n\n[Initialize Rocky Project](command:rocky.init)\n[Open Documentation](command:rocky.openDocumentation)",
        "when": "!rocky.hasProject"
      },
      {
        "view": "rocky.models",
        "contents": "No models found in this workspace.\n\nCreate a `.rocky` file under `models/`, or browse the [documentation](command:rocky.openDocumentation) for examples.",
        "when": "rocky.hasProject"
      },
      {
        "view": "rocky.runs",
        "contents": "Open a Rocky project to see run history.",
        "when": "!rocky.hasProject"
      },
      {
        "view": "rocky.runs",
        "contents": "No runs yet. Run your pipeline to see history here.\n\n[Run Pipeline](command:rocky.run)\n[Plan (Dry Run)](command:rocky.plan)",
        "when": "rocky.hasProject"
      },
      {
        "view": "rocky.sources",
        "contents": "Open a Rocky project to discover sources.",
        "when": "!rocky.hasProject"
      },
      {
        "view": "rocky.sources",
        "contents": "Sources are discovered from your configured adapter.\n\n[Discover Sources](command:rocky.discover)",
        "when": "rocky.hasProject"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "rocky.refreshModels",
          "when": "view == rocky.models",
          "group": "navigation"
        },
        {
          "command": "rocky.refreshRuns",
          "when": "view == rocky.runs",
          "group": "navigation"
        },
        {
          "command": "rocky.refreshSources",
          "when": "view == rocky.sources",
          "group": "navigation"
        },
        {
          "command": "rocky.refreshInfo",
          "when": "view == rocky.info",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "rocky.compile",
          "when": "view == rocky.models && viewItem == rockyModel",
          "group": "1_run@1"
        },
        {
          "command": "rocky.test",
          "when": "view == rocky.models && viewItem == rockyModel",
          "group": "1_run@2"
        },
        {
          "command": "rocky.showLineage",
          "when": "view == rocky.models && viewItem == rockyModel",
          "group": "2_inspect@1"
        },
        {
          "command": "rocky.history",
          "when": "view == rocky.models && viewItem == rockyModel",
          "group": "2_inspect@2"
        },
        {
          "command": "rocky.metrics",
          "when": "view == rocky.models && viewItem == rockyModel",
          "group": "2_inspect@3"
        },
        {
          "command": "rocky.optimize",
          "when": "view == rocky.models && viewItem == rockyModel",
          "group": "2_inspect@4"
        }
      ]
    },
    "keybindings": [
      {
        "command": "rocky.commandPalette",
        "key": "ctrl+shift+r",
        "mac": "cmd+shift+r"
      }
    ]
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src/",
    "bundle": "node esbuild.mjs",
    "bundle:watch": "node esbuild.mjs --watch",
    "bundle:webview": "node scripts/bundle-webview.mjs",
    "pretest": "npm run compile && npm run bundle -- --dev",
    "test": "node ./out/test/runTest.js",
    "test:unit": "vitest run",
    "test:all": "npm run test:unit && npm test",
    "package": "vsce package",
    "package:local": "vsce package -o rocky.vsix",
    "install:local": "npm run package:local && code --install-extension rocky.vsix --force",
    "uninstall:local": "code --uninstall-extension rocky-data.rocky",
    "vscode:prepublish": "npm run compile && npm run bundle:webview && npm run bundle"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^25.6.2",
    "@types/vscode": "^1.116.0",
    "@viz-js/viz": "^3.26.0",
    "@vscode/test-electron": "^2.5.2",
    "@vscode/vsce": "^3.9.1",
    "esbuild": "^0.28.0",
    "eslint": "^10.3.0",
    "glob": "^13.0.6",
    "json-schema-to-typescript": "^15.0.4",
    "mocha": "^11.7.5",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.2",
    "vitest": "^4.1.4"
  },
  "overrides_comment": "Force-patch transitive deps that haven't been bumped upstream yet — fixes Dependabot alerts #17 (jsdiff DoS), #18 (serialize-javascript RCE), #19 (serialize-javascript CPU exhaustion), and the GHSA-q3j6-qgpj-74h6 / GHSA-v39h-62p7-jpjc fast-uri path-traversal/host-confusion advisories (transitive via ajv → @vscode/test-electron). Drop these once upstreams ship the bumps.",
  "overrides": {
    "serialize-javascript": "^7.0.5",
    "diff": "^8.0.3",
    "fast-uri": "^3.1.2"
  }
}
