# Rocky runtime artifacts
.rocky-state.redb
.rocky_state
.rocky_state.redb.lock
.rocky/
*.duckdb
*.duckdb.wal
*.duckdb.tmp/

# Captured POC outputs (regenerated by run.sh)
pocs/**/expected/*.json
pocs/**/expected/*.dot
pocs/**/expected/*.txt
pocs/**/expected/*.jsonl
pocs/**/expected/*.log
pocs/**/expected/*.err
pocs/**/expected/*.stderr
!pocs/**/expected/.gitkeep
# Aspirational target shapes for not-yet-implemented commands stay tracked.
!pocs/**/expected/*.example.json

# Generated Rocky repos emitted by `rocky import-dbt --output-dir imported/`
# in the import-dbt POCs. Same role as expected/ — fully regenerated each run.
pocs/**/imported/

# Rendered screencast artefacts emitted by VHS — the .tape file is the
# tracked source; the .mp4 / .gif lives in docs/public/ when needed.
pocs/**/*.mp4
pocs/**/*.gif

# Python (benchmarks, dbt-migration POC)
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
.python-version

# Rust (in case anyone scratches a Rust file here)
target/

# Editor / OS / agents
.DS_Store
.idea/
.vscode/
.claude/
*.swp

# Secrets — never commit
.env
.env.*
!.env.example

# Scratch space
scratch/
tmp/
