  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "typecheck:webview": "tsc -p webview-ui/tsconfig.webview.json",
    "lint": "eslint src/ webview-ui/",
    "tailwind": "tailwindcss -c webview-ui/tailwind.config.js -i webview-ui/styles/base.css -o webview-ui/styles/tailwind.generated.css",
    "tailwind:watch": "npm run tailwind -- --watch",
    "prebundle": "npm run tailwind",
    "bundle": "node esbuild.mjs",
    "prebundle:watch": "npm run tailwind",
    "bundle:watch": "node esbuild.mjs --watch",
    "pretest": "npm run compile && npm run bundle -- --dev",
    "test": "node ./out/test/runTest.js",
    "test:unit": "vitest run",
    "test:all": "npm run test:unit && npm test",
    "package": "vsce package",
    "package:local": "vsce package -o rocky.vsix",
    "install:local": "npm run package:local && code --install-extension rocky.vsix --force",
    "uninstall:local": "code --uninstall-extension rocky-data.rocky",
    "vscode:prepublish": "npm run compile && npm run bundle"
  },
